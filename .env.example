# ============================================
# ChatGPT2API 环境变量配置示例
# ============================================

# 认证密钥（必填）
CHATGPT2API_AUTH_KEY=your_secret_key_here

# Web / API 暴露端口
CHATGPT2API_PORT=3000

# 后端同步线程池容量；实时监控显示入口线程等待时可适当调高。
CHATGPT2API_THREAD_TOKENS=80

# iCloud Privacy Mail 内部服务（启用 Compose 的 local-icloud profile；不会单独暴露端口）
ICLOUD_PRIVACY_MAIL_BASE_URL=http://icloud-privacy-mail:8787
# Apple 登录对共享代理出口较敏感，默认让 Apple/iCloud 官方域名直连。
ICLOUD_PRIVACY_MAIL_NO_PROXY=127.0.0.1,localhost,icloud-privacy-mail,.apple.com,.icloud.com,.apple.com.cn,.icloud.com.cn
# 仅供注册中心的外部自动领取 API 使用；控制台管理不需要单独密钥。
ICLOUD_PRIVACY_MAIL_API_KEY=change-me

# Docker 镜像，可固定为 ghcr.io/auucoder/gptgrok2api:<version>
CHATGPT2API_IMAGE=ghcr.io/auucoder/gptgrok2api:latest

# 基础 URL（可选，用于生成图片 URL）
# CHATGPT2API_BASE_URL=https://your-domain.com

# ============================================
# 存储后端配置
# ============================================

# 存储后端类型（可选值: json, sqlite, postgres, git）
# 默认: json
STORAGE_BACKEND=json

# ============================================
# 数据库配置（当 STORAGE_BACKEND=sqlite/postgres 时使用）
# ============================================

# PostgreSQL 示例
# DATABASE_URL=postgresql://user:password@localhost:5432/chatgpt2api

# Supabase 示例
# DATABASE_URL=postgresql://postgres.xxx:password@aws-1-us-west-1.pooler.supabase.com:5432/postgres

# SQLite 示例（不指定时自动使用 data/accounts.db）
# DATABASE_URL=sqlite:///app/data/accounts.db

# ============================================
# Git 仓库配置（当 STORAGE_BACKEND=git 时使用）
# ============================================

# Git 仓库地址（必填）
# GIT_REPO_URL=

# Git 访问令牌（必填）
# GIT_TOKEN=your_git_token_here

# Git 分支（可选，默认: main）
# GIT_BRANCH=main

# Git 仓库中的文件路径（可选，默认: accounts.json）
# GIT_FILE_PATH=accounts.json

# Git 仓库中的用户密钥文件路径（可选，默认: auth_keys.json）
# GIT_AUTH_KEYS_FILE_PATH=auth_keys.json

# ============================================
# WARP / FlareSolverr 稳定代理配置（可选）
# ============================================

# docker-compose.warp.yml 暴露到宿主机的端口
# WARP_SOCKS_PORT=40000
# PRIVOXY_PORT=40080
# FLARESOLVERR_PORT=8191

# FlareSolverr 日志与时区
# FLARESOLVERR_LOG_LEVEL=info
# TZ=Asia/Shanghai

# Optional iCloud Privacy Mail sidecar (`--profile local-icloud`)
# sidecar 容器内监听 8787；Warp 编排默认映射到宿主机 127.0.0.1:8788。
# ICLOUD_PRIVACY_MAIL_API_KEY=replace_with_a_long_random_secret
# 返回给浏览器和外部调用方的邮箱 API 地址，必须从容器外可访问。
# 本机 Warp Compose 默认映射到 8788；服务器请改为对外 HTTPS 地址。
# ICLOUD_PRIVACY_MAIL_PUBLIC_BASE_URL=http://127.0.0.1:8788
# ICLOUD_PRIVACY_MAIL_IMAGE=chatgpt2api/icloud-privacy-mail:2026.07.14.1
# WARP 编排默认通过内部 Privoxy 请求 Apple；标准编排可按需填写外部 HTTP 代理。
# ICLOUD_PRIVACY_MAIL_HTTP_PROXY=http://privoxy:8118
# ICLOUD_PRIVACY_MAIL_HTTPS_PROXY=http://privoxy:8118
# ICLOUD_PRIVACY_MAIL_NO_PROXY=127.0.0.1,localhost,icloud-privacy-mail

# Cloudflare WARP+ License Key（可选）
# WARP_LICENSE_KEY=

# 初始化 proxy_runtime 默认值
# CHATGPT2API_PROXY_RUNTIME_ENABLED=true
# CHATGPT2API_PROXY_RUNTIME_EGRESS_MODE=single_proxy
# CHATGPT2API_PROXY_RUNTIME_PROXY_URL=http://privoxy:8118
# CHATGPT2API_PROXY_RUNTIME_RESOURCE_PROXY_URL=
# 宿主机直接运行 Uvicorn 时，Compose 默认 privoxy 地址会自动映射到此 URL。
# CHATGPT2API_HOST_PRIVOXY_URL=http://127.0.0.1:40080
# CHATGPT2API_HOST_FLARESOLVERR_URL=http://127.0.0.1:8191
# CHATGPT2API_PROXY_RUNTIME_SKIP_SSL_VERIFY=false
# CHATGPT2API_PROXY_RUNTIME_RESET_STATUS_CODES=403

# Cloudflare clearance 刷新配置
# CHATGPT2API_PROXY_RUNTIME_CLEARANCE_ENABLED=true
# CHATGPT2API_PROXY_RUNTIME_CLEARANCE_MODE=flaresolverr
# CHATGPT2API_FLARESOLVERR_URL=http://flaresolverr:8191
# CHATGPT2API_PROXY_RUNTIME_CLEARANCE_TIMEOUT_SEC=60
# CHATGPT2API_PROXY_RUNTIME_CLEARANCE_REFRESH_INTERVAL=3600
# CHATGPT2API_PROXY_RUNTIME_WARM_UP_ON_START=false
# CHATGPT2API_PROXY_RUNTIME_BROWSER=chrome
# CHATGPT2API_PROXY_RUNTIME_USER_AGENT=
